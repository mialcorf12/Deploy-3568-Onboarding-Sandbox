    <rules>
        <fullName>ANZ Date Acct Added in Portal</fullName>
        <actions>
            <name>Inform_SS_of_new_ANZ_Customer_for_uD10_Access</name>
            <type>Alert</type>
        </actions>
        <actions>
            <name>Fill_Portal_Added_Date</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Jeanne_This_is_a_new_acct_Needs_Program_Assignment</name>
            <type>Task</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Account.uLab_Acct_Number__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Date_Added_to_Portal__c</field>
            <operation>equals</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Account.BillingCountry</field>
            <operation>equals</operation>
            <value>AU,NZ,SG</value>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Check flag for Billing Address Change</fullName>
        <actions>
            <name>Billing_Address_Change</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>OR(ISCHANGED(BillingAddress),  AND(ISNEW(),  NOT(ISNULL(BillingAddress))))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Check flag for Shipping Address Change</fullName>
        <actions>
            <name>Shipping_Address_Change</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>OR(ISCHANGED(ShippingAddress ),  AND(ISNEW(),  NOT(ISNULL(ShippingAddress ))))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Cloud Customer Autocheck</fullName>
        <actions>
            <name>Check_the_box</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Account.BillingCountry</field>
            <operation>equals</operation>
            <value>US</value>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Latest_SW_Agreement_Signed__c</field>
            <operation>greaterOrEqual</operation>
            <value>4/11/2025</value>
        </criteriaItems>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Hub Invite</fullName>
        <active>false</active>
        <criteriaItems>
            <field>Account.Hub_MVP_Invitation_Date__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Account.Hub_Invite_Sent__c</field>
            <operation>equals</operation>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
        <workflowTimeTriggers>
            <actions>
                <name>Update_Hub_Invite_Sent_Date</name>
